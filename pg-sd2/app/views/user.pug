doctype html
html
  head
    title User Profile
  body
    if user
      h1= user.name
      p Email: #{user.email}
      p Bio: #{user.bio}

      h2 Listings by this user
      if listings.length
        ul
          each listing in listings
            li
              a(href=`/listings/${listing.id}`)= listing.title
      else
        p This user has no listings.
    else
      p User not found.